    {
      "id": "elf",
      "name": "Elfo",
      "description": "Los elfos son una raza mágica de gracia sobrenatural, viviendo en el mundo pero no completamente parte de él. Viven en lugares de belleza etérea, en medio de antiguos bosques o en torres plateadas brillantes.",
      "age": "Aunque alcanzan la madurez física aproximadamente a la misma edad que los humanos, la comprensión elfa de la adultez va más allá del crecimiento físico para abarcar la experiencia mundial. Un elfo típicamente reclama la adultez y un nombre adulto alrededor de los 100 años y puede vivir hasta 750 años.",
      "size": "Mediano",
      "movement": {
        "walking": 30
      },
      "ability_bonuses": {
        "dexterity": 2
      },
      "traits": [
        {
          "id": "vision_en_la_oscuridad",
          "trait_type": "racial_base",
          "name": "Visión en la oscuridad",
          "description": "Puedes ver en la oscuridad hasta 60 pies como si fuera luz tenue, y en luz tenue como si fuera luz brillante. No puedes discernir colores en la oscuridad, solo tonos de gris.",
          "mechanics": {
            "type": "vision",
            "target": "senses",
            "operation": "add",
            "value": "darkvision",
            "condition": null,
            "metadata": {
              "range": 60,
              "vision_type": "darkvision"
            }
          }
        },
        {
          "id": "inmunidad_al_encantamiento",
          "trait_type": "racial_base",
          "name": "Inmunidad al encantamiento",
          "description": "Tienes ventaja en las tiradas de salvación contra ser encantado, y la magia no puede ponerte a dormir.",
          "mechanics": {
            "type": "modifier",
            "target": "saving_throw",
            "operation": "advantage",
            "value": null,
            "condition": "vs_charmed",
            "metadata": {
              "additional": "immune_magic_sleep"
            }
          }
        },
        {
          "id": "trance",
          "trait_type": "racial_base",
          "name": "Trance",
          "description": "Los elfos no necesitan dormir. En lugar de eso, meditan profundamente, permaneciendo semiconscientes, durante 4 horas al día. (La palabra común para tal meditación es \"trance\".) Mientras meditas, puedes soñar después de una moda; tales sueños son en realidad ejercicios mentales que se han convertido en reflejos a través de años de práctica. Después de descansar de esta manera, obtienes el mismo beneficio que un humano obtiene de 8 horas de sueño.",
          "mechanics": {
            "type": "passive",
            "target": null,
            "operation": null,
            "value": null,
            "condition": null,
            "metadata": {
              "mechanic_description": "Reemplaza 8 horas de sueño por 4 horas de trance"
            }
          }
        }
      ],
