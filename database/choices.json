    "Metamagic": [
      { "id": "cuidado", "name": "Cuidado", "description": "Cuando lanzas un conjuro que obliga a otras criaturas a hacer una tirada de salvación, puedes gastar 1 punto de hechicería para elegir un número de esas criaturas igual a 1 + el modificador de tu aptitud mágica (mínimo una criatura). Una criatura elegida automáticamente tiene éxito en su tirada de salvación contra el conjuro." },
      { "id": "distante", "name": "Distante", "description": "Cuando lanzas un conjuro que tiene un alcance de 5 pies o superior, puedes gastar 1 punto de hechicería para duplicar el alcance del conjuro. Cuando lanzas un conjuro de toque, puedes gastar 1 punto de hechicería para hacer que el alcance del conjuro sea de 30 pies." },
      { "id": "empoderado", "name": "Empoderado", "description": "Cuando lanzas un conjuro que inflige daño, puedes gastar 1 punto de hechicería para rerrolar un número de dados de daño igual a tu modificador de aptitud mágica (mínimo uno). Debes usar los nuevos resultados. Puedes usar Metamagia Empoderado incluso si ya has usado una opción de metamagia diferente en el conjuro." },
      { "id": "extendido", "name": "Extendido", "description": "Cuando lanzas un conjuro que tiene una duración de 1 minuto o más, puedes gastar 1 punto de hechicería para duplicar su duración, hasta un máximo de 24 horas." },
      { "id": "sutil", "name": "Sutil", "description": "Cuando lanzas un conjuro, puedes gastar 1 punto de hechicería para lanzarlo sin componentes somáticos ni verbales." },
      { "id": "rapido", "name": "Rápido", "description": "Cuando lanzas un conjuro que tiene un tiempo de lanzamiento de 1 acción, puedes gastar 2 puntos de hechicería para cambiar el tiempo de lanzamiento a 1 acción bonus para este lanzamiento." },
      { "id": "ampliado", "name": "Ampliado", "description": "Cuando lanzas un conjuro que apunta solo a una criatura y no tiene un alcance personal, puedes gastar un número de puntos de hechicería igual al nivel del conjuro para apuntar a una segunda criatura en el alcance con el mismo conjuro (1 punto si el conjuro es un truco)." },
      { "id": "elevado", "name": "Elevado", "description": "Cuando lanzas un conjuro que obliga a una criatura a hacer una tirada de salvación para resistir sus efectos, puedes gastar 3 puntos de hechicería para dar desventaja a una criatura objetivo en su primera tirada de salvación contra el conjuro." }
